{
  "name": "@yama662607/anki-mcp",
  "version": "0.4.1",
  "description": "MCP server for safe, review-first Anki authoring on official Anki concepts",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "anki-mcp": "dist/src/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yama662607/anki-mcp.git"
  },
  "homepage": "https://github.com/yama662607/anki-mcp#readme",
  "bugs": {
    "url": "https://github.com/yama662607/anki-mcp/issues"
  },
  "keywords": [
    "anki",
    "anki-connect",
    "mcp",
    "model-context-protocol",
    "flashcards",
    "spaced-repetition",
    "learning",
    "typescript"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:mcp": "vitest run tests/mcpServer.test.ts",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "e2e:anki": "node scripts/e2e-real-anki.mjs",
    "install:addon": "node scripts/install-anki-addon.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck",
    "postinstall": "node scripts/install-anki-addon.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
